local function formatTime(s)
	if s < 0 then s = 0 end
	local h = math.floor(s/3600)
	local m = math.floor((s%3600)/60)
	local sec = math.floor(s%60)
	return string.format("%02d:%02d:%02d",h,m,sec)
end

-- Hàm quét tối đa 3 trang (~300 server) và phân bổ vùng thông minh
local function getTargetServerId()
	local placeId = game.PlaceId
	local currentJobId = game.JobId
	local validServers = {}

	local cursor = ""
	for page = 1, 3 do
		local url = "https://games.roproxy.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
		if cursor ~= "" then
			url = url .. "&cursor=" .. cursor
		end

		-- Bọc toàn bộ quá trình Get và Decode vào pcall để tránh crash do proxy lỗi
		local success, result = pcall(function()
			local response = game:HttpGet(url)
			return HttpService:JSONDecode(response)
		end)

		if success and result and result.data then
			for _, server in ipairs(result.data) do
				if server.playing and server.maxPlayers and server.playing < server.maxPlayers and server.id ~= currentJobId then
					table.insert(validServers, server.id)
				end
			end
			cursor = result.nextPageCursor
			if not cursor or cursor == "" then
				break
			end
		else
			break
		end

		task.wait(0.5)
	end

	-- --- LOGIC PHÂN CHIA SERVER ---
	local totalServers = #validServers
	if totalServers > 0 then
		if isUnknownAccount then
			-- Sử dụng rng:NextInteger thay cho math.random
			return validServers[rng:NextInteger(1, totalServers)]
		else
			local chunk_size = math.floor(totalServers / 12)
			if chunk_size < 2 then chunk_size = 2 end

			local start_index = ((accIndex - 1) * chunk_size) + 1
			local end_index = accIndex * chunk_size

			if start_index > totalServers then start_index = 1 end
			if end_index > totalServers then end_index = totalServers end
			if end_index < start_index then end_index = start_index end

			return validServers[rng:NextInteger(start_index, end_index)]
		end
	end
	return nil
end

local function safeTeleport()
	for i = 1, 3 do
		local targetServerId = getTargetServerId()

		if targetServerId then
			local ok = pcall(function()
				TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServerId, player)
			end)
			if ok then return true end
		else
			local ok = pcall(function()
				TeleportService:Teleport(game.PlaceId, player)
			end)
			if ok then return true end
		end
		task.wait(5)
	end
	return false
end

local startTime = os.clock()
local isRejoining = false
local customWaitTime = nil

while true do
	if not isRejoining then
		local remain = REJOIN_TIME - (os.clock() - startTime)
		
		-- Nếu đang trong chế độ chờ thử lại (sau khi lỗi) thì ép thời gian hiển thị
		if customWaitTime then
			remain = customWaitTime
			customWaitTime = customWaitTime - 1
			if customWaitTime <= 0 then customWaitTime = nil end
		end

		if remain > 0 then
			label.Text = formatTime(remain)
			task.wait(1)
		else
			isRejoining = true
			label.Text = "Server Hopping..."

			local success = safeTeleport()

			if success then
				-- Đóng băng vòng lặp tại đây để chờ Roblox ngắt kết nối hoàn toàn, tránh chạy tiếp tốn tài nguyên
				label.Text = "Teleporting..."
				while true do task.wait(1) end 
			else
				-- Thất bại: Đặt thời gian chờ thử lại là 10 giây một cách tường minh
				label.Text = "Lỗi! Thử lại sau 10s..."
				customWaitTime = 10
				startTime = os.clock() -- Reset lại mốc gốc
				task.wait(10)
			end

			isRejoining = false
		end
	else
		task.wait(1)
	end
end
