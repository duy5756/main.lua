local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local REJOIN_TIME = 3600 -- 1 tiếng đổi server giải phóng RAM
local FAIL_RETRY_TIME = 15 -- Thời gian chờ thử lại nếu lỗi teleport

local player = Players.LocalPlayer

-- DANH SÁCH 12 ACC CỐ ĐỊNH ĐẦY ĐỦ CỦA BẠN
local myAccounts = {
	["tannguyenn11"] = 1,
	["kobeoikk2008"] = 2,
	["khoimoiiwq"] = 3,
	["rwqryua665"] = 4,
	["huy382038"] = 5,
	["bwawege"] = 6,
	["noridomigaming"] = 7,
	["HvdviaDGy3"] = 8,
	["hello876757"] = 9,
	["Meky_Sempai"] = 10,
	["ngthanhok"] = 11,
	["Benkenzzzzz1234"] = 12
}

local currentName = player.Name
local accIndex = myAccounts[currentName]
local isUnknownAccount = false

-- TRƯỜNG HỢP: Nếu không tìm thấy tên trong danh sách
if not accIndex then
	isUnknownAccount = true
	local nameSeed = #currentName
	for i = 1, #currentName do
		nameSeed = nameSeed + string.byte(currentName, i)
	end
	accIndex = nameSeed
end

-- Khởi tạo bộ sinh số ngẫu nhiên dựa trên bộ sinh số độc lập
local rng = Random.new(os.time() + accIndex)

-- Hàm quét tối đa 3 trang server và phân bổ vùng thông minh
local function getTargetServerId()
	local placeId = game.PlaceId
	local currentJobId = game.JobId
	local validServers = {}
	local cursor = ""

	for page = 1, 3 do
		local url = "https://games.roproxy.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
		if cursor ~= "" then
			url = url .. "&cursor=" .. cursor
		end

		local success, result = pcall(function()
			local response = game:HttpGet(url)
			return HttpService:JSONDecode(response)
		end)

		if success and result and result.data then
			for _, server in ipairs(result.data) do
				if server.playing and server.maxPlayers and server.playing < server.maxPlayers and server.id ~= currentJobId then
					table.insert(validServers, server.id)
				end
			end
			cursor = result.nextPageCursor
			if not cursor or cursor == "" then
				break
			end
		else
			break
		end
		task.wait(0.25)
	end

	-- --- LOGIC PHÂN CHIA SERVER THEO TÀI KHOẢN ---
	local totalServers = #validServers
	if totalServers > 0 then
		if isUnknownAccount then
			return validServers[rng:NextInteger(1, totalServers)]
		else
			local chunk_size = math.floor(totalServers / 12)
			if chunk_size < 1 then chunk_size = 1 end

			local start_index = ((accIndex - 1) * chunk_size) + 1
			local end_index = accIndex * chunk_size

			if start_index > totalServers then start_index = 1 end
			if end_index > totalServers then end_index = totalServers end
			if end_index < start_index then end_index = start_index end

			return validServers[rng:NextInteger(start_index, end_index)]
		end
	end
	return nil
end

local function safeTeleport()
	for i = 1, 3 do
		local targetServerId = getTargetServerId()
		local ok

		if targetServerId then
			ok = pcall(function()
				TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServerId, player)
			end)
		else
			ok = pcall(function()
				TeleportService:Teleport(game.PlaceId, player)
			end)
		end
		
		if ok then return true end
		task.wait(3)
	end
	return false
end

-- VÒNG LẶP CHÍNH CHẠY NGẦM
while true do
	task.wait(REJOIN_TIME) -- Chờ đủ 1 tiếng chạy ngầm hoàn toàn
	
	local success = safeTeleport()

	if success then
		-- Tự hủy script để giải phóng RAM tối đa trong khi chờ Roblox ngắt kết nối
		script.Disabled = true
		return
	else
		-- Nếu lỗi, đợi một khoảng thời gian cố định rồi tự động thử lại ở vòng lặp sau
		task.wait(FAIL_RETRY_TIME)
	end
end
