local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local REJOIN_TIME = 3600
local REJOIN_WAIT = 25

local player = Players.LocalPlayer

pcall(function()
	local pg = player:WaitForChild("PlayerGui")
	local old = pg:FindFirstChild("RejoinTimer")
	if old then old:Destroy() end
end)

local gui = Instance.new("ScreenGui")
gui.Name = "RejoinTimer"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0,140,0,28)
label.Position = UDim2.new(1,-150,0,10)
label.BackgroundColor3 = Color3.fromRGB(0,0,0)
label.BackgroundTransparency = 0.35
label.TextColor3 = Color3.fromRGB(255,255,255)
label.BorderSizePixel = 0
label.TextScaled = true
label.Parent = gui

local function formatTime(s)
	local h = math.floor(s/3600)
	local m = math.floor((s%3600)/60)
	local sec = math.floor(s%60)
	return string.format("%02d:%02d:%02d",h,m,sec)
end

local function safeTeleport()
	for i = 1, 3 do
		local ok = pcall(function()
			TeleportService:Teleport(game.PlaceId, player)
		end)

		if ok then
			return true
		end

		task.wait(2)
	end

	return false
end

local startTime = os.clock()
local isRejoining = false

while true do
	if not isRejoining then
		local remain = REJOIN_TIME - (os.clock() - startTime)

		if remain > 0 then
			label.Text = formatTime(remain)
			task.wait(1)
		else
			isRejoining = true
			label.Text = "Rejoining..."

			local success = safeTeleport()

			-- nếu teleport OK → chờ server chuyển
			if success then
				task.wait(REJOIN_WAIT)
			else
				task.wait(5) -- fail thì retry nhanh
			end

			-- reset lại cycle an toàn
			startTime = os.clock()
			isRejoining = false
		end
	else
		task.wait(1)
	end
end

